---
interface Props {
  title: string;
  date: string;
  category: string;
  excerpt: string;
  readTime: string;
  author: string;
  tags?: string[];
}

const { title, date, category, excerpt, readTime, author, tags } = Astro.props;

const categoryColors: Record<string, { bg: string; border: string; text: string }> = {
  opinion: { bg: '#fff0f0', border: '#e12d39', text: '#c8102e' },
  review: { bg: '#fdf6e3', border: '#b8860b', text: '#8b6914' },
  news: { bg: '#e0f2fe', border: '#0284c7', text: '#0369a1' },
  guide: { bg: '#f3e8ff', border: '#9333ea', text: '#7e22ce' },
  data: { bg: '#ecfdf5', border: '#059669', text: '#047857' },
};

const cat = categoryColors[category] || categoryColors.opinion;

const formattedDate = new Date(date).toLocaleDateString('en-IN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | DriveGuruji</title>
  <meta name="description" content={excerpt} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --bg:#ffffff;--bg2:#f7f7f8;--bg3:#f0f0f2;
      --border:#e5e5e7;
      --text:#1a1a1a;--text2:#4a4a4a;--text3:#717179;
      --red:#e12d39;--red-light:#fff0f0;
      --gold:#b8860b;--gold-light:#fdf6e3;
      --blue:#0066cc;--green:#059669;--orange:#ea580c;
      --font:'Inter',sans-serif;
      --mono:'JetBrains Mono',monospace;
      --radius:10px;
      --shadow:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
    }
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--text);font-family:var(--font);font-weight:400;line-height:1.5;overflow-x:hidden}
    .site-nav{position:fixed;top:0;left:0;right:0;z-index:500;display:flex;align-items:center;justify-content:space-between;padding:14px 48px;background:rgba(255,255,255,.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--border)}
    .nav-brand{font-size:20px;font-weight:800;letter-spacing:-.02em;color:var(--text);text-decoration:none}
    .nav-brand span{color:var(--red)}
    .nav-back{font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);text-decoration:none;transition:color .2s}
    .nav-back:hover{color:var(--red)}
    .article-wrap{max-width:720px;margin:0 auto;padding:120px 24px 80px}
    .art-category{display:inline-block;font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;font-weight:500;padding:4px 12px;border-radius:4px;margin-bottom:20px}
    .art-title{font-size:clamp(28px,4.5vw,44px);font-weight:800;line-height:1.15;letter-spacing:-.03em;margin-bottom:18px;color:var(--text)}
    .art-excerpt{font-size:16px;color:var(--text2);line-height:1.7;font-weight:400;margin-bottom:24px;border-left:3px solid var(--red);padding-left:18px}
    .art-meta-row{display:flex;align-items:center;gap:14px;font-family:var(--mono);font-size:11px;color:var(--text3);letter-spacing:.04em;margin-bottom:40px;padding-bottom:24px;border-bottom:1px solid var(--border)}
    .art-meta-dot{width:3px;height:3px;border-radius:50%;background:var(--text3)}
    .article-body{font-size:16px;line-height:1.85;font-weight:400;color:var(--text2)}
    .article-body h2{font-size:24px;font-weight:700;margin:40px 0 16px;color:var(--text);letter-spacing:-.02em}
    .article-body h3{font-size:19px;font-weight:600;margin:32px 0 12px;color:var(--text)}
    .article-body p{margin-bottom:18px}
    .article-body strong{color:var(--text);font-weight:600}
    .article-body em{color:var(--text2);font-style:italic}
    .article-body a{color:var(--red);text-decoration:underline;text-underline-offset:3px;transition:color .2s}
    .article-body a:hover{color:var(--blue)}
    .article-body ul,.article-body ol{margin:14px 0 22px 22px}
    .article-body li{margin-bottom:8px}
    .article-body blockquote{border-left:3px solid var(--red);padding:14px 20px;margin:24px 0;background:var(--red-light);border-radius:0 var(--radius) var(--radius) 0;font-style:italic;color:var(--text2)}
    .article-body code{font-family:var(--mono);font-size:14px;background:var(--bg2);padding:2px 7px;border-radius:4px;color:var(--red)}
    .article-body pre{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:18px;overflow-x:auto;margin:22px 0}
    .article-body pre code{background:none;padding:0;color:var(--text)}
    .article-body hr{border:none;border-top:1px solid var(--border);margin:36px 0}
    .article-body table{width:100%;border-collapse:collapse;margin:22px 0;font-size:14px}
    .article-body th{font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);font-weight:500;text-align:left;padding:10px 14px;border-bottom:2px solid var(--border);background:var(--bg2)}
    .article-body td{padding:10px 14px;border-bottom:1px solid var(--border);color:var(--text2)}
    .article-body tr:hover td{background:var(--bg2)}
    .art-tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:40px;padding-top:24px;border-top:1px solid var(--border)}
    .art-tag{font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;font-weight:500;padding:4px 12px;border-radius:4px;background:var(--bg2);border:1px solid var(--border);color:var(--text3);text-decoration:none;transition:border-color .2s,color .2s}
    .art-tag:hover{border-color:var(--red);color:var(--red)}
    .art-footer{max-width:720px;margin:0 auto;padding:36px 24px 60px;text-align:center}
    .art-footer-cta{display:inline-block;font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;font-weight:500;color:var(--red);text-decoration:none;padding:12px 28px;border:1px solid var(--red);border-radius:var(--radius);transition:background .2s,color .2s}
    .art-footer-cta:hover{background:var(--red);color:#fff}
    .art-footer-copy{font-family:var(--mono);font-size:11px;color:var(--text3);margin-top:20px;letter-spacing:.04em}
    @media(max-width:640px){
      .site-nav{padding:12px 18px}
      .article-wrap{padding:100px 18px 60px}
      .art-excerpt{font-size:15px;padding-left:14px}
      .art-meta-row{flex-wrap:wrap;gap:10px}
    }
  </style>
</head>
<body>

<nav class="site-nav">
  <a href="/" class="nav-brand">Drive<span>Guruji</span></a>
  <a href="/articles" class="nav-back">&larr; All Articles</a>
</nav>

<article class="article-wrap">
  <header>
    <div class="art-category" style={`background:${cat.bg};border:1px solid ${cat.border};color:${cat.text}`}>
      {category}
    </div>
    <h1 class="art-title">{title}</h1>
    <p class="art-excerpt">{excerpt}</p>
    <div class="art-meta-row">
      <span>{author}</span>
      <div class="art-meta-dot"></div>
      <span>{readTime} read</span>
      <div class="art-meta-dot"></div>
      <span>{formattedDate}</span>
    </div>
  </header>

  <div class="article-body">
    <slot />
  </div>

  {tags && tags.length > 0 && (
    <div class="art-tags">
      {tags.map((tag: string) => (
        <span class="art-tag">#{tag}</span>
      ))}
    </div>
  )}
</article>

<div class="art-footer">
  <a href="/articles" class="art-footer-cta">&larr; All Articles</a>
  <p class="art-footer-copy">&copy; 2026 DriveGuruji by Exif Media. All rights reserved. &middot; All prices ex-showroom Delhi</p>
</div>

</body>
</html>
