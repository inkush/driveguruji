---
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const categoryColors = {
  opinion: { bg: '#fff0f0', border: '#e12d39', text: '#c8102e' },
  review: { bg: '#fdf6e3', border: '#b8860b', text: '#8b6914' },
  news: { bg: '#e0f2fe', border: '#0284c7', text: '#0369a1' },
  guide: { bg: '#f3e8ff', border: '#9333ea', text: '#7e22ce' },
  data: { bg: '#ecfdf5', border: '#059669', text: '#047857' },
} as const;

const articleImages: Record<string, string> = {
  'ola-electric-10-lakh-sales-means-nothing': '/images/articles/ola-electric.jpg',
  'hyundai-creta-electric-range-reality-check': '/images/articles/creta-electric.jpg',
  'amt-vs-cvt-vs-dct-vs-imt-which-automatic-is-best': '/images/articles/amt-vs-cvt.jpg',
  '2026-car-price-hikes-who-is-ripping-you-off': '/images/articles/price-hikes-2026.jpg',
  'best-tyres-for-indian-roads-every-scenario': '/images/articles/best-tyres.jpg',
  'hyundai-creta-5-year-ownership-cost-real-numbers': '/images/articles/creta-ownership.jpg',
  'indian-cars-that-share-the-same-engine': '/images/articles/shared-engines.jpg',
  'kia-seltos-5-year-ownership-cost-full-breakdown': '/images/articles/seltos-ownership.jpg',
  'nexon-vs-venue-5-year-ownership-cost': '/images/articles/nexon-vs-venue.jpg',
  'renault-duster-2026-comeback-not-what-you-think': '/images/articles/renault-duster.jpg',
  'what-is-adblue-diesel-cars-india': '/images/articles/adblue-diesel.jpg',
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Articles — DriveGuruji</title>
  <meta name="description" content="Sharp, opinionated automotive journalism. No OEM-pleasing fluff. Real numbers, real takes." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --bg:#ffffff;--bg2:#f7f7f8;--bg3:#f0f0f2;
      --border:#e5e5e7;
      --text:#1a1a1a;--text2:#4a4a4a;--text3:#717179;
      --red:#e12d39;--red-light:#fff0f0;
      --gold:#b8860b;--gold-light:#fdf6e3;
      --blue:#0066cc;--green:#059669;--orange:#ea580c;
      --font:'Inter',sans-serif;
      --mono:'JetBrains Mono',monospace;
      --radius:10px;
      --shadow:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
      --shadow-md:0 4px 12px rgba(0,0,0,.08);
      --shadow-lg:0 10px 40px rgba(0,0,0,.12);
    }
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--text);font-family:var(--font);font-weight:400;line-height:1.5;overflow-x:hidden}
    .site-nav{position:fixed;top:0;left:0;right:0;z-index:500;display:flex;align-items:center;justify-content:space-between;padding:14px 48px;background:rgba(255,255,255,.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--border)}
    .nav-brand{font-size:20px;font-weight:800;letter-spacing:-.02em;color:var(--text);text-decoration:none}
    .nav-brand span{color:var(--red)}
    .nav-back{font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);text-decoration:none;transition:color .2s}
    .nav-back:hover{color:var(--red)}
    .page-header{max-width:1100px;margin:0 auto;padding:110px 24px 0}
    .page-eye{font-family:var(--mono);font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--red);font-weight:500;margin-bottom:10px}
    .page-title{font-size:clamp(28px,4vw,42px);font-weight:800;letter-spacing:-.03em;line-height:1.1;margin-bottom:10px;color:var(--text)}
    .page-sub{font-size:15px;color:var(--text3);font-weight:400;max-width:520px;line-height:1.6;margin-bottom:48px}
    .articles-grid{max-width:1100px;margin:0 auto;padding:0 24px 80px;display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:20px}
    .acard{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;text-decoration:none;color:inherit;transition:box-shadow .3s,transform .3s}
    .acard:hover{box-shadow:var(--shadow-md);transform:translateY(-4px)}
    .acard-img{width:100%;height:200px;object-fit:cover;display:block}
    .acard-body{padding:20px}
    .acard-cat{display:inline-block;font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;font-weight:500;padding:3px 10px;border-radius:4px;margin-bottom:10px}
    .acard-title{font-size:17px;font-weight:700;line-height:1.3;letter-spacing:-.02em;margin-bottom:8px;color:var(--text)}
    .acard-excerpt{font-size:13px;color:var(--text3);line-height:1.55;font-weight:400;margin-bottom:16px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
    .acard-foot{display:flex;align-items:center;justify-content:space-between;padding-top:12px;border-top:1px solid var(--border);font-family:var(--mono);font-size:10px;color:var(--text3);letter-spacing:.04em}
    .acard-read{color:var(--red);font-weight:500;text-transform:uppercase;letter-spacing:.08em}
    .footer{text-align:center;padding:40px 24px 60px;font-family:var(--mono);font-size:11px;color:var(--text3);letter-spacing:.04em;border-top:1px solid var(--border)}
    @media(max-width:640px){
      .site-nav{padding:12px 18px}
      .page-header{padding:100px 18px 0}
      .articles-grid{padding:0 18px 60px;grid-template-columns:1fr}
    }
  </style>
</head>
<body>

<nav class="site-nav">
  <a href="/" class="nav-brand">Drive<span>Guruji</span></a>
  <a href="/" class="nav-back">&larr; Home</a>
</nav>

<div class="page-header">
  <div class="page-eye">Articles</div>
  <h1 class="page-title">Sharp Takes, Real Numbers</h1>
  <p class="page-sub">No OEM-pleasing fluff. No "it depends" without the answer. Opinionated automotive journalism backed by data.</p>
</div>

<div class="articles-grid">
  {sorted.map((article) => {
    const cat = categoryColors[article.data.category as keyof typeof categoryColors] || categoryColors.opinion;
    const imgSrc = articleImages[article.id] || '/images/articles/ola-electric.jpg';
    const formattedDate = new Date(article.data.date).toLocaleDateString('en-IN', { month: 'short', day: 'numeric', year: 'numeric' });
    return (
      <a href={`/articles/${article.id}`} class="acard">
        <img class="acard-img" src={imgSrc} alt={article.data.title} loading="lazy" />
        <div class="acard-body">
          <div class="acard-cat" style={`background:${cat.bg};border:1px solid ${cat.border};color:${cat.text}`}>
            {article.data.category}
          </div>
          <div class="acard-title">{article.data.title}</div>
          <p class="acard-excerpt">{article.data.excerpt}</p>
          <div class="acard-foot">
            <span>{article.data.readTime} read &middot; {formattedDate}</span>
            <span class="acard-read">Read &rarr;</span>
          </div>
        </div>
      </a>
    );
  })}
</div>

<div class="footer">
  &copy; 2026 DriveGuruji by Exif Media. All rights reserved. &middot; All prices ex-showroom Delhi
</div>

</body>
</html>
